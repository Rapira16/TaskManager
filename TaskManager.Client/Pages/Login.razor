@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor
@using TaskManager.Client.Services
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<MudThemeProvider Theme="_theme" />
<MudSnackbarProvider />
<MudDialogProvider />

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Syne:wght@@400;600;700;800&family=DM+Sans:wght@@300;400;500&display=swap');

    * {
        box-sizing: border-box;
    }

    body, .mud-layout {
        background: #0d0d0f !important;
        font-family: 'DM Sans', sans-serif !important;
    }

    /* ── Sidebar ── */
    .mud-drawer {
        background: #0d0d0f !important;
        border-right: 1px solid #1a1a1e !important;
        width: 220px !important;
    }

    .sidebar-logo {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 28px 20px 20px;
        border-bottom: 1px solid #181820;
        margin-bottom: 8px;
    }

    .sidebar-logo-icon {
        width: 32px;
        height: 32px;
        background: #3b82f6;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        flex-shrink: 0;
    }

    .sidebar-logo-text {
        font-family: 'Syne', sans-serif;
        font-size: 1rem;
        font-weight: 700;
        color: #f2f0eb;
        letter-spacing: -0.02em;
    }

    .sidebar-section-label {
        font-size: 0.62rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #2a2a32;
        padding: 16px 20px 6px;
    }

    /* Nav links */
    .mud-nav-link {
        border-radius: 8px !important;
        margin: 1px 10px !important;
        padding: 9px 12px !important;
        color: #444 !important;
        font-size: 0.85rem !important;
        font-weight: 500 !important;
        transition: background 0.15s, color 0.15s !important;
    }

        .mud-nav-link:hover {
            background: #161618 !important;
            color: #aaa !important;
        }

        .mud-nav-link.active {
            background: #13131a !important;
            color: #f2f0eb !important;
            border: 1px solid #1f1f28 !important;
        }

        .mud-nav-link .mud-nav-link-icon {
            color: inherit !important;
            font-size: 18px !important;
            margin-right: 10px !important;
            opacity: 0.7;
        }

        .mud-nav-link.active .mud-nav-link-icon {
            opacity: 1;
            color: #3b82f6 !important;
        }

    /* Divider */
    .mud-divider {
        border-color: #181820 !important;
        margin: 8px 10px !important;
    }

    /* ── AppBar ── */
    .mud-appbar {
        background: #0d0d0f !important;
        border-bottom: 1px solid #1a1a1e !important;
        box-shadow: none !important;
        height: 56px !important;
    }

    .appbar-inner {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        width: 100%;
        padding-right: 8px;
    }

    .appbar-user {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .appbar-avatar {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        background: #1c1c24;
        border: 1px solid #252530;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        color: #555;
    }

    .logout-btn {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border-radius: 8px;
        border: 1px solid #1c1c24;
        background: transparent;
        color: #444;
        font-size: 0.78rem;
        font-weight: 500;
        font-family: 'DM Sans', sans-serif;
        cursor: pointer;
        transition: border-color 0.15s, color 0.15s;
    }

        .logout-btn:hover {
            border-color: #ef4444;
            color: #ef4444;
        }

    /* ── Main content ── */
    .mud-main-content {
        background: #0d0d0f !important;
        padding: 0 !important;
    }
</style>

<AuthorizeView>
    <Authorized>
        <MudLayout>
            <MudAppBar Elevation="0" Fixed="true">
                <MudIconButton Icon="@Icons.Material.Filled.Menu"
                               Style="color:#333"
                               Edge="Edge.Start"
                               OnClick="@ToggleDrawer" />
                <MudSpacer />
                <div class="appbar-inner">
                    <div class="appbar-user">
                        <div class="appbar-avatar">◈</div>
                        <button class="logout-btn" @onclick="Logout">
                            <span>Выйти</span>
                        </button>
                    </div>
                </div>
            </MudAppBar>

            <MudDrawer @bind-Open="_drawerOpen"
                       ClipMode="DrawerClipMode.Always"
                       Elevation="0">

                <div class="sidebar-logo">
                    <div class="sidebar-logo-icon">◈</div>
                    <span class="sidebar-logo-text">TaskManager</span>
                </div>

                <div class="sidebar-section-label">Навигация</div>

                <MudNavMenu>
                    <MudNavLink Href="/"
                                Icon="@Icons.Material.Filled.Dashboard"
                                Match="NavLinkMatch.All">
                        Дашборд
                    </MudNavLink>
                    <MudNavLink Href="/projects"
                                Icon="@Icons.Material.Filled.Folder">
                        Проекты
                    </MudNavLink>
                    <MudNavLink Href="/tasks"
                                Icon="@Icons.Material.Filled.CheckBox">
                        Задачи
                    </MudNavLink>

                    <AuthorizeView Roles="Admin" Context="adminAuth">
                        <MudDivider Class="my-2" />
                        <div class="sidebar-section-label">Администрирование</div>
                        <MudNavLink Href="/users"
                                    Icon="@Icons.Material.Filled.People">
                            Пользователи
                        </MudNavLink>
                    </AuthorizeView>
                </MudNavMenu>
            </MudDrawer>

            <MudMainContent>
                @Body
            </MudMainContent>
        </MudLayout>
    </Authorized>

    <NotAuthorized>
        @Body
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool _drawerOpen = true;

    private MudTheme _theme = new MudTheme
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#3b82f6",
            Secondary = "#8b5cf6",
            Background = "#0d0d0f",
            Surface = "#111114",
            AppbarBackground = "#0d0d0f",
            DrawerBackground = "#0d0d0f",
            DrawerText = "#aaaaaa",
            TextPrimary = "#e8e6e1",
            TextSecondary = "#555555",
            Divider = "#1a1a1e",
            TableLines = "#1a1a1e",
        }
    };

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}
