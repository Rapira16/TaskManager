@page "/"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using TaskManager.Client.Models
@using TaskManager.Client.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject ITaskService TaskService
@inject IProjectService ProjectService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Дашборд — Task Manager</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6">
    Дашборд
</MudText>

@if (_isLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}

<!-- Статистика -->
<MudGrid Class="mb-6">
    <MudItem xs="12" sm="6" md="3">
        <MudCard Elevation="2" Style="border-left: 4px solid #1976d2;">
            <MudCardContent>
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Всего задач</MudText>
                <MudText Typo="Typo.h3" Color="Color.Primary">@_totalTasks</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudCard Elevation="2" Style="border-left: 4px solid #ff9800;">
            <MudCardContent>
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">В работе</MudText>
                <MudText Typo="Typo.h3" Style="color: #ff9800;">@_inProgressTasks</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudCard Elevation="2" Style="border-left: 4px solid #4caf50;">
            <MudCardContent>
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Выполнено</MudText>
                <MudText Typo="Typo.h3" Style="color: #4caf50;">@_doneTasks</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudCard Elevation="2" Style="border-left: 4px solid #f44336;">
            <MudCardContent>
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Просрочено</MudText>
                <MudText Typo="Typo.h3" Color="Color.Error">@_overdueTasks</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

<!-- Последние задачи -->
<MudGrid>
    <MudItem xs="12" md="8">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Последние задачи</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudButton Href="/tasks" Variant="Variant.Text" Color="Color.Primary">
                        Все задачи
                    </MudButton>
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent Class="pa-0">
                <MudSimpleTable Dense="true" Hover="true" Style="width:100%;">
                    <thead>
                        <tr>
                            <th>Задача</th>
                            <th>Проект</th>
                            <th>Статус</th>
                            <th>Приоритет</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_recentTasks.Count == 0)
                        {
                            <tr>
                                <td colspan="4">
                                    <MudText Class="pa-4">Задач пока нет</MudText>
                                </td>
                            </tr>
                        }
                        @foreach (var task in _recentTasks)
                        {
                            <tr>
                                <td>
                                    <MudText Typo="Typo.body2">@task.Title</MudText>
                                    @if (task.IsOverdue)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Class="ml-1">
                                            Просрочена
                                        </MudChip>
                                    }
                                </td>
                                <td>
                                    <MudText Typo="Typo.body2">@task.Project?.Name</MudText>
                                </td>
                                <td>
                                    <StatusChip Status="@task.Status" StatusName="@task.StatusName" />
                                </td>
                                <td>
                                    <PriorityChip Priority="@task.Priority" PriorityName="@task.PriorityName" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <!-- Проекты -->
    <MudItem xs="12" md="4">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Проекты</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudButton Href="/projects" Variant="Variant.Text" Color="Color.Primary">
                        Все
                    </MudButton>
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                @if (_projects.Any())
                {
                    @foreach (var project in _projects.Take(5))
                    {
                        <MudPaper Elevation="0" Class="pa-3 mb-2"
                                  Style="background: #f5f5f5; border-radius: 8px;">
                            <MudText Typo="Typo.subtitle2">@project.Name</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @project.TasksCount задач · @project.MembersCount участников
                            </MudText>
                        </MudPaper>
                    }
                }
                else
                {
                    <MudText Color="Color.Secondary">Проектов пока нет</MudText>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private bool _isLoading = true;
    private List<TaskItemDto> _recentTasks = new();
    private List<ProjectDto> _projects = new();
    private int _totalTasks = 0;
    private int _inProgressTasks = 0;
    private int _doneTasks = 0;
    private int _overdueTasks = 0;

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;

        try
        {
            var tasksTask = TaskService.GetPagedAsync(pageSize: 50);
            var projectsTask = ProjectService.GetAllAsync();

            await Task.WhenAll(tasksTask, projectsTask);

            var tasksResult = tasksTask.Result;
            _projects = projectsTask.Result;

            _totalTasks = tasksResult.TotalCount;
            _recentTasks = tasksResult.Items.Take(10).ToList();

            _inProgressTasks = tasksResult.Items.Count(t => t.Status == 1);
            _doneTasks = tasksResult.Items.Count(t => t.Status == 2);
            _overdueTasks = tasksResult.Items.Count(t => t.IsOverdue);
        }
        finally
        {
            _isLoading = false;
        }
    }
}